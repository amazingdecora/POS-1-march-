# Copy to `.env` on the Lightsail host (same directory as `docker-compose.yml`).
# Same content as `.env.deploy.example` (that file is hidden: starts with a dot).
# Usage:  cp deploy.env.example .env
# Docker Compose reads `.env` automatically. Do not commit `.env`.

# GHCR image names. Replace OWNER with your GitHub username/org and repo path.
# Example:
# SERVER_IMAGE=ghcr.io/OWNER/pos-1-march-server:latest
# CLIENT_IMAGE=ghcr.io/OWNER/pos-1-march-client:latest
SERVER_IMAGE=ghcr.io/OWNER/pos-1-march-server:latest
CLIENT_IMAGE=ghcr.io/OWNER/pos-1-march-client:latest

# Public browser origin for your app (no trailing slash). Examples:
# CORS_ORIGIN=http://YOUR_STATIC_IP:8080
# CORS_ORIGIN=https://pos.yourdomain.com
CORS_ORIGIN=http://localhost:8080

# Strong secret for JWT (required for real deployments)
JWT_SECRET=generate-a-long-random-string

# Database (defaults match docker-compose; change in production)
POSTGRES_DB=amazing_decora
POSTGRES_USER=amazing_user
POSTGRES_PASSWORD=change-this-strong-password

# Admin UI default password (first seed only; change after first login workflow if you add that)
ADMIN_DEFAULT_PASSWORD=change-this-admin-password

# Optional host port overrides (firewall must allow CLIENT_HOST_PORT)
# CLIENT_HOST_PORT=80
# API_HOST_PORT=4001
# HOST_PG_PORT=5432
